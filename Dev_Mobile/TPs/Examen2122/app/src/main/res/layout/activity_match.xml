<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MatchActivity">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarMatch"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/purple_700"
        app:title="Tennis"
        app:titleTextColor="@android:color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Noms des joueurs -->
    <TextView
        android:id="@+id/tvPlayers"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="16sp"
        android:textColor="@android:color/darker_gray"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarMatch"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Tableau des sets -->
    <TableLayout
        android:id="@+id/tableSets"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/tvPlayers"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Set 1 -->
        <TableRow>
            <TextView
                android:text="Set 1"
                android:padding="16dp"/>

            <TextView
                android:id="@+id/tvSet1Player1"
                android:text="0"
                android:padding="16dp"/>

            <TextView
                android:id="@+id/tvSet1Player2"
                android:text="0"
                android:padding="16dp"/>
        </TableRow>

        <!-- Set 2 -->
        <TableRow>
            <TextView
                android:text="Set 2"
                android:padding="16dp"/>

            <TextView
                android:id="@+id/tvSet2Player1"
                android:text="0"
                android:padding="16dp"/>

            <TextView
                android:id="@+id/tvSet2Player2"
                android:text="0"
                android:padding="16dp"/>
        </TableRow>

        <!-- Set 3 -->
        <TableRow>
            <TextView
                android:text="Set 3"
                android:padding="16dp"/>

            <TextView
                android:id="@+id/tvSet3Player1"
                android:text="0"
                android:padding="16dp"/>

            <TextView
                android:id="@+id/tvSet3Player2"
                android:text="0"
                android:padding="16dp"/>
        </TableRow>

    </TableLayout>

    <!-- Bouton saisir un jeu -->
    <Button
        android:id="@+id/btnStartGame"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SAISIR UN JEU"
        android:layout_marginTop="48dp"
        app:cornerRadius="0dp"
        app:layout_constraintTop_toBottomOf="@id/tableSets"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnOkMathc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OK"
        app:cornerRadius="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.907"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnStartGame"
        app:layout_constraintVertical_bias="0.809" />

</androidx.constraintlayout.widget.ConstraintLayout>
